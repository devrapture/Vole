---
export interface Props {
  heading: string;
  ctaText: string;
  ctaHref: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const { heading, ctaText, ctaHref, secondaryText, secondaryHref } = Astro.props;
---

<section class="py-20 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-text leading-tight">
      {heading}
    </h2>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-bg font-semibold text-sm hover:bg-emerald-400 transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        {ctaText}
      </a>
      {
        secondaryText && secondaryHref && (
          <a
            href={secondaryHref}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-border text-text font-medium text-sm hover:bg-surface transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
          >
            {secondaryText}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        )
      }
    </div>
  </div>
</section>
