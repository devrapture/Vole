---
export interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="rounded-lg border border-border bg-surface p-6 transition-all duration-200 hover:border-accent/40 hover:glow-green">
  <div class="w-10 h-10 rounded-lg border border-border bg-[#0a0a0c] flex items-center justify-center mb-4">
    <span class="text-lg">{icon}</span>
  </div>
  <h3 class="text-lg font-semibold text-text mb-2">{title}</h3>
  <p class="text-sm text-muted leading-relaxed">{description}</p>
</div>
