---
// Static placeholder — client JS hydrates with live data
const REPO = "devrapture/Vole";
---

<section class="py-20 px-4 border-t border-border">
  <div class="max-w-4xl mx-auto text-center" id="github-stars">
    <span class="inline-block text-xs font-semibold tracking-widest uppercase text-accent mb-4">
      Community
    </span>
    <h2 class="text-3xl md:text-4xl font-bold text-text leading-tight">
      Love vole-clean? Star us on GitHub
    </h2>
    <p class="mt-4 text-lg text-muted max-w-2xl mx-auto">
      Help others discover vole-clean by starring the repository.
    </p>

    <!-- Star count (updated by JS) -->
    <div class="mt-8 flex items-center justify-center gap-3" id="star-count-display">
      <svg class="w-6 h-6 text-muted" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      <span class="text-5xl font-bold text-text tabular-nums" id="star-count">0</span>
    </div>

    <!-- Stargazer avatars (updated by JS) -->
    <div class="mt-6 flex items-center justify-center" id="stargazers-list">
      <div class="flex -space-x-2" id="stargazers-avatars"></div>
    </div>

    <!-- CTA -->
    <div class="mt-8">
      <a
        href={`https://github.com/${REPO}`}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-bg font-semibold text-sm hover:bg-emerald-400 transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        Star on GitHub
      </a>
    </div>

    <p class="mt-4 text-sm text-muted">
      <a href={`https://github.com/${REPO}/stargazers`} class="hover:text-text transition-colors">
        View all stargazers
      </a>
    </p>
  </div>
</section>

<script>
  const REPO = "devrapture/Vole";
  const CACHE_KEY = "vole-github-stars";
  const CACHE_TTL = 300_000; // 5 minutes

  function render(data) {
    const countEl = document.getElementById("star-count");
    const avatarsEl = document.getElementById("stargazers-avatars");
    if (countEl) countEl.textContent = data.stars;
    if (avatarsEl && data.users) {
      avatarsEl.innerHTML = data.users
        .slice(0, 30)
        .map(
          (u) =>
            `<a href="https://github.com/${u.login}" target="_blank" rel="noopener noreferrer" class="inline-block w-10 h-10 rounded-full border-2 border-bg overflow-hidden transition-transform hover:scale-110 hover:-translate-y-0.5" title="${u.login}">
              <img src="${u.avatar_url}" alt="${u.login}" class="w-full h-full object-cover" loading="lazy" />
            </a>`
        )
        .join("");
    }
  }

  async function fetchStars() {
    const cached = sessionStorage.getItem(CACHE_KEY);
    if (cached) {
      try {
        const parsed = JSON.parse(cached);
        if (Date.now() - parsed.timestamp < CACHE_TTL) {
          render(parsed.data);
          return;
        }
      } catch {}
    }

    try {
      const [repoRes, starsRes] = await Promise.all([
        fetch(`https://api.github.com/repos/${REPO}`),
        fetch(`https://api.github.com/repos/${REPO}/stargazers?per_page=30`),
      ]);
      const repo = await repoRes.json();
      const stargazers = await starsRes.json();
      const data = {
        stars: repo.stargazers_count ?? 0,
        users: Array.isArray(stargazers) ? stargazers : [],
      };
      sessionStorage.setItem(
        CACHE_KEY,
        JSON.stringify({ timestamp: Date.now(), data })
      );
      render(data);
    } catch {
      // silently fail — keep static placeholder
    }
  }

  fetchStars();
  setInterval(fetchStars, 60_000);
</script>
