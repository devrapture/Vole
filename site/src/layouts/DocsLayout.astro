---
import BaseLayout from "./BaseLayout.astro";

const title = Astro.props.content?.title ?? "";
const description = Astro.props.content?.description ?? "";

const sidebarLinks = [
  { section: "Getting Started", items: [
    { href: "/docs/installation", label: "Installation" },
    { href: "/docs/usage", label: "Usage" },
  ]},
  { section: "Reference", items: [
    { href: "/docs/configuration", label: "Configuration" },
    { href: "/docs/how-it-works", label: "How it works" },
  ]},
];
---

<BaseLayout pageTitle={title} pageDescription={description}>
  <div class="max-w-6xl mx-auto px-6 py-16 md:py-20">
    <div class="flex gap-12">
      <aside class="hidden md:block w-56 shrink-0 sticky top-24 self-start">
        <nav>
          <div class="mb-8">
            <a href="/docs" class="font-mono font-semibold text-sm text-text hover:text-accent transition-colors">
              ← Docs
            </a>
          </div>
          {
            sidebarLinks.map((group) => (
              <div class="mb-6">
                <h4 class="text-xs font-semibold tracking-widest uppercase text-muted mb-3">
                  {group.section}
                </h4>
                <ul class="space-y-2">
                  {group.items.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        class="text-sm text-muted hover:text-text transition-colors"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </nav>
      </aside>
      <article class="doc-content min-w-0 flex-1 prose prose-invert max-w-none">
        <slot />
      </article>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Unset margins on first/last children inside article content */
  .doc-content > :first-child {
    margin-top: 0 !important;
  }
  .doc-content > :last-child {
    margin-bottom: 0 !important;
  }

  /* macOS traffic light dots on expressive-code terminal frames */
  .expressive-code .frame.is-terminal .header {
    position: relative;
    padding-left: 52px !important;
  }

  .expressive-code .frame.is-terminal .header::before {
    content: '' !important;
    position: absolute !important;
    pointer-events: none !important;
    left: 16px !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    width: 40px !important;
    height: 10px !important;
    background:
      radial-gradient(circle at 5px 5px, #ff5f57 5px, transparent 0),
      radial-gradient(circle at 20px 5px, #febc2e 5px, transparent 0),
      radial-gradient(circle at 35px 5px, #28c840 5px, transparent 0) !important;
    opacity: 1 !important;
    -webkit-mask: none !important;
    mask: none !important;
  }
</style>
